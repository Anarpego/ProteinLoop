# ProteinLoop local demo
SIMULATOR_URL=http://127.0.0.1:8000
PORT=4001

# OpenAI-compatible Gemma boundary used by the Phoenix harness.
# Do not include /v1 here; the app appends /v1/models and /v1/chat/completions.
GEMMA_ENDPOINT=http://127.0.0.1:8001
GEMMA_MODEL=google/gemma-4-E2B-it
GEMMA_API_KEY=
GEMMA_RECEIVE_TIMEOUT_MS=120000
GEMMA_MAX_TOKENS=1024

# AMD-hosted vLLM/Gemma profile.
# HF_TOKEN is required when the selected Hugging Face model needs gated access.
HF_TOKEN=
VLLM_MODEL=google/gemma-4-E2B-it
VLLM_PORT=8001
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MM_LIMITS=image=0,audio=0
